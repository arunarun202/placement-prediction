# Django Core Secret Key
SECRET_KEY=your_django_secret_key_here

# Social Authentication: GitHub Credentials (Optional if not using GitHub login)
GITHUB_KEY=your_github_client_id_here
GITHUB_SECRET=your_github_client_secret_here

# Social Authentication: Google Credentials (Optional if not using Google login)
GOOGLE_KEY=your_google_client_id_here
GOOGLE_SECRET=your_google_client_secret_here

# Email Configuration (For password reset SMTP)
EMAIL_USER=your_email_address@gmail.com
EMAIL_PASSWORD=your_email_app_password_here

# Gemini API Keys (Used in placement recommendation & resume parser views)
# The application currently has fallback/hardcoded keys in code, but configure these for custom access.
GEMINI_API_KEY=your_gemini_api_key_here
